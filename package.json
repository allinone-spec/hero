{
  "name": "heroes-archive",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "npx tsx src/lib/seed.ts",
    "import-medals": "npx tsx scripts/import-medal-inventory.ts",
    "validate:foreign-medals": "npx tsx scripts/validate-foreign-medal-scoring.ts",
    "validate:medal-catalog": "npx tsx scripts/validate-medal-catalog.ts",
    "test:golden-awards": "npx tsx scripts/golden-awards.ts",
    "backfill:metadata-tags": "npx tsx scripts/backfill-metadata-tags.ts",
    "normalize:hero-taxonomy": "npx tsx scripts/normalize-all-heroes-taxonomy.ts",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "worker": "npx tsx -r ./src/worker-env.cjs -r tsconfig-paths/register src/worker.ts"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@stripe/stripe-js": "^8.9.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.0",
    "eslint-config-next": "^0.2.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
